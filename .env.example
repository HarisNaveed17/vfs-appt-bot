# VFS booking parameters
VFS_COUNTRY_CODE=pak
VFS_MISSION_CODE=nld
VFS_VAC_CODE=NISL
VFS_VISA_CATEGORY=TR
VFS_EMAIL=you@gmail.com

# Auth — set exactly one of these two:
#
# Option A (automated): Playwright logs in on every run using your plaintext VFS password.
# Use this for fully hands-off operation on GitHub Actions.
VFS_PASSWORD=your-vfs-password-here

# Option B (manual): Paste the accessToken from the /user/login response in browser DevTools.
# Faster per-run (no Playwright launch), but expires with the session and needs manual updates.
# Takes priority over VFS_PASSWORD if both are set.
# VFS_AUTHORIZE=EAAAAKk...

# Optional — the clientsource header captured from DevTools. Capture once and keep.
# Omit if the bot works without it (server may not validate).
# VFS_CLIENT_SOURCE=J7F3/f+...

# Gmail (create an app password at myaccount.google.com/apppasswords)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
ALERT_EMAIL_TO=you@gmail.com

# Twilio WhatsApp (use sandbox number +14155238886 for testing)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
ALERT_WHATSAPP_TO=whatsapp:+92xxxxxxxxxx

# Optional: suppress polling during these CET hours (e.g. overnight)
QUIET_HOURS_CET=23-07
