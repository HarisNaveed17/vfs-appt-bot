# VFS booking parameters
VFS_COUNTRY_CODE=pak
VFS_MISSION_CODE=nld
# Comma-separated; centres are swept in order with ONE in-page switch.
# Each entry is a code (mapped in vfs/auth.py:_VAC_LABELS) or a raw UI label.
VFS_VAC_CODE=NISL,Netherlands Lahore
VFS_VISA_CATEGORY=TR
VFS_EMAIL=you@gmail.com

# VFS account password — the browser logs in fresh every run (the page JS
# encrypts it). Required (it is the only working auth path).
VFS_PASSWORD=your-vfs-password-here

# Gmail — kept as a record/audit log of when slots opened (not watched live).
# Create an app password at myaccount.google.com/apppasswords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
ALERT_EMAIL_TO=you@gmail.com

# Pushover — the real-time alarm (Emergency priority: re-alerts until you ack).
# PUSHOVER_TOKEN: create an Application at pushover.net/apps/build
# PUSHOVER_USER: your user key from the Pushover dashboard
PUSHOVER_TOKEN=axxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PUSHOVER_USER=uxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

